# =============================================================================
# Algo VWAP — Derivatives bot
# Default testing path: Binance Futures Testnet (free demo USDT)
# Production: CoinDCX or Binance live
# =============================================================================

NODE_ENV=development
LOG_LEVEL=info

# --- Exchange selection ---
# binance_testnet  → free demo funds (recommended for testing)
# binance          → real Binance USD-M futures (real money)
# coindcx          → real CoinDCX derivatives (real money)
EXCHANGE=binance_testnet

# --- Binance (testnet OR live) ---
# Testnet keys: https://testnet.binancefuture.com → login → API Management
# These keys are NOT the same as your live Binance account keys.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Optional overrides (auto-set from EXCHANGE if omitted)
# BINANCE_BASE_URL=https://testnet.binancefuture.com
# BINANCE_BASE_URL=https://fapi.binance.com

# --- CoinDCX (only when EXCHANGE=coindcx) ---
COINDCX_API_KEY=
COINDCX_API_SECRET=
COINDCX_BASE_URL=https://api.coindcx.com
COINDCX_PUBLIC_BASE_URL=https://public.coindcx.com

# --- Derivatives / Leverage ---
DERIV_LEVERAGE=10
DERIV_LEVERAGE_BY_SYMBOL={"BTCUSDT":20,"ETHUSDT":15}
DERIV_MARGIN_TYPE=isolated
DERIV_MARGIN_CURRENCY=USDT
DERIV_ATTACH_SL_TP=true
DERIV_RESPECT_MAX_LEVERAGE=true
ALLOW_SHORT=true

# --- Risk ---
ACCOUNT_BALANCE_USDT=10000
RISK_PER_TRADE_PCT=1
MAX_DAILY_DRAWDOWN_PCT=3
MAX_CONSECUTIVE_LOSSES=3
MAX_OPEN_TRADES=3
MAX_EXPOSURE_PCT=30
MAX_NOTIONAL_TO_EQUITY=10
MIN_CONFIDENCE_SCORE=85
MIN_RISK_REWARD=2

# --- Scanner ---
SCAN_UNIVERSE_SIZE=100
MIN_DAILY_VOLUME_USDT=1000000
MAX_SPREAD_BPS=50

# --- Infra ---
DATABASE_URL=postgresql://algo:algo_secret@localhost:5432/algo_vwap?schema=public
REDIS_URL=redis://localhost:6379
BOT_API_PORT=3100
BOT_WS_PORT=3101
DASHBOARD_PORT=3000
ALERTS_ENABLED=false
