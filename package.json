{
  "name": "algo-vwap",
  "version": "1.0.0",
  "description": "Production-grade CoinDCX institutional VWAP trading bot — multi-pair scanner, order-flow analysis, automated execution",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "NODE_ENV=production node dist/main.js",
    "start:live": "NODE_ENV=production node dist/main.js",
    "backtest": "tsx src/backtest/cli.ts",
    "dashboard": "pnpm --filter dashboard dev",
    "dashboard:build": "pnpm --filter dashboard build",
    "db:generate": "prisma generate --schema src/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema src/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema src/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema src/database/prisma/schema.prisma",
    "lint": "eslint src apps --ext .ts,.tsx",
    "lint:fix": "eslint src apps --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"apps/**/*.{ts,tsx,json,css}\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"apps/**/*.{ts,tsx,json,css}\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/integration",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "prepare": "husky || true",
    "go": "pnpm dev && pnpm dashboard"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bullmq": "^5.41.0",
    "dotenv": "^16.4.7",
    "eventemitter3": "^5.0.1",
    "ioredis": "^5.5.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsyringe": "^4.8.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.6",
    "tsc-alias": "^1.8.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
